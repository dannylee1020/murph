# Murph configuration reference.
# Copy this file to .env for secrets and deployment overrides.
# Non-secret local setup defaults live in murph.config.yaml.
# Environment variables still override murph.config.yaml for hosted deployments.

## Core

# Public base URL used for local app links and some OAuth flows.
# Default: http://localhost:5173
MURPH_APP_URL=http://localhost:5173

# SQLite database path.
# Default: data/murph.sqlite
MURPH_SQLITE_PATH=data/murph.sqlite

# Secret used to encrypt stored credentials.
# Required before storing Slack tokens or integration credentials.
# Generate with: openssl rand -hex 32
MURPH_ENCRYPTION_KEY=

# Gateway heartbeat interval in milliseconds.
# Default: 900000
MURPH_HEARTBEAT_INTERVAL_MS=900000

# Retention window for stored agent run events, in days.
# Default: 30
MURPH_RUN_EVENT_RETENTION_DAYS=30

## LLM

# Provider Murph should use when creating workspace defaults.
# Allowed: openai, anthropic
# Default: openai
MURPH_DEFAULT_PROVIDER=openai

# Runtime model used when creating workspace defaults.
# Defaults: openai / gpt-5.5, anthropic / claude-opus-4-7
MURPH_DEFAULT_MODEL=gpt-5.5

# Optional provider/model override for `murph agent`.
# By default, murph agent inherits MURPH_DEFAULT_PROVIDER and MURPH_DEFAULT_MODEL.
MURPH_AGENT_PROVIDER=
MURPH_AGENT_MODEL=

# Required for OpenAI-backed agent responses.
# Get one from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Required for Anthropic-backed agent responses.
# Get one from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

## Channels

# Slack app credentials.
# Create an app at: https://api.slack.com/apps
# Default event ingress uses Socket Mode, so local installs do not need ngrok for Slack events.
# Set to http only for hosted deployments that use /api/slack/events.
SLACK_EVENTS_MODE=socket

# App-level token for Slack Socket Mode. Must start with xapp- and include connections:write.
SLACK_APP_TOKEN=

# OAuth callback: <public-origin>/api/slack/oauth/callback
# HTTP Events URL, only when SLACK_EVENTS_MODE=http: <public-origin>/api/slack/events
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Required only when SLACK_EVENTS_MODE=http.
SLACK_SIGNING_SECRET=

# Discord app credentials.
# Create an app at: https://discord.com/developers/applications
# Redirect URI: <public-origin>/api/discord/oauth/callback
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=

## Integrations

# Notion API token.
# Get one from: https://www.notion.so/my-integrations
NOTION_API_KEY=

# Notion API version.
# Default: 2026-03-11
NOTION_VERSION=2026-03-11

# Maximum Notion search results to return.
# Default: 3
NOTION_MAX_RESULTS=3

# GitHub personal access token for repository and issue context.
# Get one from: https://github.com/settings/tokens
GITHUB_PAT=

# GitHub repositories Murph may search. Comma-separated owner/repo values.
# Example: GITHUB_REPOSITORIES=acme/app,acme/api
GITHUB_REPOSITORIES=

# Granola API key.
GRANOLA_API_KEY=

# Google OAuth/access-token settings.
GOOGLE_ACCESS_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Calendar ID.
# Default: primary
GOOGLE_CALENDAR_ID=primary

# Local Obsidian vault path.
OBSIDIAN_VAULT_PATH=

## Local Tools

# Comma-separated roots that Murph's file-read tools may access.
MURPH_FILE_READ_ALLOWED_ROOTS=

# JSON list or policy value for allowed shell commands.
MURPH_SHELL_ALLOWED_COMMANDS_JSON=

## Web Search

# Allowed: tavily, brave
# Default: brave
MURPH_WEB_SEARCH_BACKEND=brave

# Brave Search API key.
# Get one from: https://api-dashboard.search.brave.com/
BRAVE_SEARCH_API_KEY=

# Optional alternate search provider.
# Get one from: https://app.tavily.com/
TAVILY_API_KEY=

## Advanced

# Timeout for optional context source calls, in milliseconds.
# Default: 3000
MURPH_CONTEXT_SOURCE_TIMEOUT_MS=3000

# Maximum optional context sources to use per run.
# Default: 3
MURPH_CONTEXT_SOURCE_MAX_OPTIONAL=3
