{
  "name": "murph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server/index.js",
  "imports": {
    "#lib/*": {
      "types": "./src/lib/*.ts",
      "default": "./dist/lib/*.js"
    }
  },
  "scripts": {
    "dev": "npm run dev:ui",
    "dev:server": "npm run build:server && npm run start",
    "dev:ui": "vite --config ui/vite.config.ts",
    "watch:server": "tsc -p tsconfig.server.json --watch --preserveWatchOutput",
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsc -p tsconfig.server.json",
    "build:ui": "vite build --config ui/vite.config.ts",
    "start": "node dist/server/index.js",
    "preview": "npm run start",
    "architecture:map": "node scripts/generate-architecture-map.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:start": "vitepress preview docs",
    "check": "npm run build:server && tsc -p tsconfig.ui.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "tslib": "2.6.2",
    "typescript": "5.4.5",
    "vite": "5.2.8",
    "vitepress": "1.6.4",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@mariozechner/pi-agent-core": "^0.73.1",
    "@mariozechner/pi-ai": "^0.73.1",
    "@mariozechner/pi-coding-agent": "^0.73.1",
    "@slack/bolt": "^3.18.0",
    "@slack/socket-mode": "^1.3.6",
    "better-sqlite3": "^11.7.0",
    "openai": "^5.10.2",
    "typebox": "^1.1.33",
    "vue": "^3.5.25",
    "ws": "^8.20.0"
  }
}
