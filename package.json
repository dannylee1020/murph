{
  "name": "murph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/app/runtime/server.js",
  "bin": {
    "murph": "app/cli/murph"
  },
  "engines": {
    "node": ">=22"
  },
  "imports": {
    "#app/*": {
      "types": "./app/*.ts",
      "default": "./dist/app/*.js"
    }
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "test": "vitest run",
    "check": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.ui.json --noEmit",
    "build": "tsc -p tsconfig.server.json && vite build --config app/ui/vite.config.ts",
    "start": "node dist/app/runtime/server.js",
    "docs": "node scripts/sync-docs-public.mjs && vitepress build docs",
    "docs:dev": "node scripts/sync-docs-public.mjs && vitepress dev docs"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tslib": "2.6.2",
    "typescript": "5.4.5",
    "vite": "5.2.8",
    "vitepress": "1.6.4",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@earendil-works/pi-agent-core": "^0.78.0",
    "@earendil-works/pi-ai": "^0.78.0",
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@slack/bolt": "^3.18.0",
    "@slack/socket-mode": "^1.3.6",
    "better-sqlite3": "^11.7.0",
    "openai": "^5.10.2",
    "typebox": "^1.1.33",
    "vue": "^3.5.25",
    "ws": "^8.20.0",
    "yaml": "^2.9.0"
  }
}
