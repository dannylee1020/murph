#!/usr/bin/env bash
set -euo pipefail

SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_SOURCE" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" >/dev/null 2>&1 && pwd)"
  LINK_TARGET="$(readlink "$SCRIPT_SOURCE")"
  if [[ "$LINK_TARGET" == /* ]]; then
    SCRIPT_SOURCE="$LINK_TARGET"
  else
    SCRIPT_SOURCE="$SCRIPT_DIR/$LINK_TARGET"
  fi
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" >/dev/null 2>&1 && pwd)"
DEFAULT_APP_DIR="$(cd "$SCRIPT_DIR/../.." >/dev/null 2>&1 && pwd)"

MURPH_APP_DIR_EXPLICIT="${MURPH_APP_DIR+x}"
MURPH_INSTALL_DIR_EXPLICIT="${MURPH_INSTALL_DIR+x}"
MURPH_HOME="${MURPH_HOME:-$HOME/.murph}"
MURPH_APP_DIR="${MURPH_APP_DIR:-${MURPH_INSTALL_DIR:-$DEFAULT_APP_DIR}}"
MURPH_PID_FILE="${MURPH_PID_FILE:-$MURPH_HOME/murph.pid}"
MURPH_LOG_FILE="${MURPH_LOG_FILE:-$MURPH_HOME/murph.log}"
MURPH_PORT="${MURPH_PORT:-5173}"
MURPH_URL="${MURPH_URL:-http://localhost:$MURPH_PORT}"
SOURCE_ARCHIVE_URL="${MURPH_SOURCE_ARCHIVE:-https://github.com/dannylee1020/murph/archive/refs/heads/main.tar.gz}"
MURPH_BIN_DIR="${MURPH_BIN_DIR:-$HOME/.local/bin}"
MURPH_DEPS_BIN="${MURPH_DEPS_DIR:-$MURPH_HOME/deps}/bin"
export PATH="$MURPH_DEPS_BIN:$MURPH_BIN_DIR:$PATH"
MURPH_DISTRIBUTION="${MURPH_DISTRIBUTION:-team}"
if [[ "$MURPH_DISTRIBUTION" != "team" && "$MURPH_DISTRIBUTION" != "personal" ]]; then
  printf '%s\n' "MURPH_DISTRIBUTION must be team or personal." >&2
  exit 1
fi
export MURPH_DISTRIBUTION

default_distribution() {
  printf '%s\n' "$MURPH_DISTRIBUTION"
}

usage() {
  if [[ "$(default_distribution)" == "team" ]]; then
    cat <<'EOF'
Usage: murph <command> [options]

Commands:
  start [--background]  Start Murph Team.
  stop [--force]        Stop the background Murph Team process.
  restart              Restart Murph Team in the background.
  status               Show process and health status.
  doctor               Check local setup.
  setup [section]      Run the Team setup workflow.
  credentials <cmd>    List and inspect local credentials.
  admin <cmd>          Manage operator and subscriber dashboard URLs.
  agent [prompt]       Chat with Murph's setup and plugin agent.
  policy <command>     List, preview, and save policy configuration.
  logs [-f]            Show runtime logs.
  open                 Open Murph Team setup in a browser.
  build                Build Murph.
  update               Download latest source, install dependencies, and build.
  uninstall            Remove Murph-owned local files and CLI link.
  help                 Show this help.
EOF
    return
  fi
  cat <<'EOF'
Usage: murph <command> [options]

Commands:
  start [--background]  Start Murph Personal.
  stop [--force]        Stop the background Murph Personal process.
  restart              Restart Murph Personal in the background.
  status               Show process and health status.
  doctor               Check local setup.
  setup [section]      Run the Personal setup workflow.
  credentials <cmd>    List and inspect local credentials.
  agent [prompt]       Chat with Murph's setup and plugin agent.
  policy <command>     List, preview, and save policy configuration.
  logs [-f]            Show runtime logs.
  open                 Open Murph Personal setup in a browser.
  build                Build Murph.
  update               Download latest source, install dependencies, and build.
  uninstall            Remove Murph-owned local files and CLI link.
  help                 Show this help.
EOF
}

fail() {
  printf '%s\n' "$1" >&2
  exit 1
}

have_command() {
  command -v "$1" >/dev/null 2>&1
}

require_app() {
  if [[ ! -f "$MURPH_APP_DIR/package.json" ]]; then
    cat >&2 <<EOF
Murph is not installed at $MURPH_APP_DIR.
Install with:
  curl -fsSL https://murph-agent.com/install.sh | bash
EOF
    exit 1
  fi
}

require_runtime() {
  require_app
  local distribution="${1:-$(default_distribution)}"
  local entrypoint
  entrypoint="$(runtime_entrypoint "$distribution")"
  [[ -f "$MURPH_APP_DIR/$entrypoint" ]] || fail "Murph is not built. Run: murph build"
}

runtime_entrypoint() {
  case "$1" in
    personal)
      printf 'dist/murph-personal/runtime/server.js\n'
      ;;
    team|"")
      printf 'dist/murph-team/runtime/server.js\n'
      ;;
    *)
      fail "Unknown Murph distribution: $1"
      ;;
  esac
}

pid_value() {
  [[ -f "$MURPH_PID_FILE" ]] || return 1
  local pid
  pid="$(cat "$MURPH_PID_FILE" 2>/dev/null || true)"
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "$pid"
}

is_pid_running() {
  local pid="$1"
  kill -0 "$pid" >/dev/null 2>&1
}

health_check() {
  have_command curl || return 1
  curl -fsS --max-time 2 "$MURPH_URL/api/health" >/dev/null 2>&1
}

health_payload() {
  have_command curl || return 1
  curl -fsS --max-time 2 "$MURPH_URL/api/health" 2>/dev/null
}

health_check_murph() {
  local payload
  payload="$(health_payload)" || return 1
  printf '%s' "$payload" | node -e 'let raw = ""; process.stdin.on("data", c => raw += c); process.stdin.on("end", () => { try { const data = JSON.parse(raw); process.exit(data && data.service === "murph" ? 0 : 1); } catch { process.exit(1); } });'
}

port_listener_pid() {
  local pid=""
  if have_command lsof; then
    pid="$(lsof -tiTCP:"$MURPH_PORT" -sTCP:LISTEN 2>/dev/null | head -n 1 || true)"
  elif have_command fuser; then
    pid="$(fuser "$MURPH_PORT/tcp" 2>/dev/null | awk '{ print $1 }' || true)"
  fi
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "$pid"
}

fail_port_unavailable() {
  local pid="" owner=""
  if pid="$(port_listener_pid)"; then
    owner=" by PID $pid"
  fi

  fail "Port $MURPH_PORT is already in use$owner, and $MURPH_URL is not a Murph server. Stop that process, or set MURPH_PORT intentionally after updating OAuth callback URLs and local tunnels."
}

ensure_port_available_for_start() {
  if health_check_murph; then
    return 0
  fi

  if health_check; then
    fail_port_unavailable
  fi

  if port_listener_pid >/dev/null 2>&1; then
    fail_port_unavailable
  fi
}

stop_responding_murph() {
  have_command node || return 1
  health_check_murph || return 1

  local pid
  pid="$(port_listener_pid)" || return 1
  kill "$pid" >/dev/null 2>&1 || true

  local attempt
  for attempt in {1..20}; do
    if ! is_pid_running "$pid"; then
      rm -f "$MURPH_PID_FILE"
      printf 'Stopped Murph process listening on %s.\n' "$MURPH_URL"
      return
    fi
    sleep 0.25
  done

  kill -9 "$pid" >/dev/null 2>&1 || true
  rm -f "$MURPH_PID_FILE"
  printf 'Force-stopped Murph process listening on %s.\n' "$MURPH_URL"
}

pretty_json() {
  node -e 'let raw = ""; process.stdin.on("data", c => raw += c); process.stdin.on("end", () => { try { console.log(JSON.stringify(JSON.parse(raw), null, 2)); } catch { process.stdout.write(raw); } });'
}

require_http_api() {
  have_command curl || fail "curl is required for murph policy."
  have_command node || fail "node is required for murph policy."
  health_check || fail "Murph is not running at $MURPH_URL. Start it with: murph start --background"
}

wait_for_health() {
  local attempt
  for attempt in {1..20}; do
    if health_check; then
      return 0
    fi
    sleep 0.25
  done
  return 1
}

start_foreground() {
  local distribution="${1:-$(default_distribution)}"
  local entrypoint
  entrypoint="$(runtime_entrypoint "$distribution")"
  require_runtime "$distribution"
  if health_check_murph; then
    printf 'Murph is already running at %s\n' "$MURPH_URL"
    return
  fi
  ensure_port_available_for_start

  printf 'Starting Murph %s on %s\n' "$distribution" "$MURPH_URL"
  printf 'Press Ctrl-C to stop.\n'
  cd "$MURPH_APP_DIR"
  PORT="$MURPH_PORT" MURPH_DISTRIBUTION="$distribution" node "$entrypoint"
}

start_background() {
  local distribution="${1:-$(default_distribution)}"
  local entrypoint
  entrypoint="$(runtime_entrypoint "$distribution")"
  require_runtime "$distribution"
  mkdir -p "$MURPH_HOME"

  if health_check_murph; then
    printf 'Murph is already running at %s\n' "$MURPH_URL"
    return
  fi
  ensure_port_available_for_start

  local pid
  if pid="$(pid_value)" && ! is_pid_running "$pid"; then
    rm -f "$MURPH_PID_FILE"
  fi

  cd "$MURPH_APP_DIR"
  nohup env PORT="$MURPH_PORT" MURPH_DISTRIBUTION="$distribution" node "$entrypoint" >>"$MURPH_LOG_FILE" 2>&1 &
  pid="$!"
  printf '%s\n' "$pid" >"$MURPH_PID_FILE"

  if wait_for_health; then
    printf 'Murph %s started in the background.\n' "$distribution"
    printf 'URL: %s/setup\n' "$MURPH_URL"
    printf 'PID: %s\n' "$pid"
    printf 'Logs: %s\n' "$MURPH_LOG_FILE"
    return
  fi

  printf 'Murph did not become healthy after startup.\n' >&2
  printf 'Last log lines:\n' >&2
  tail -n 30 "$MURPH_LOG_FILE" >&2 2>/dev/null || true
  exit 1
}

stop_background() {
  local force=false
  if [[ "${1:-}" == "--force" ]]; then
    force=true
  elif [[ $# -gt 0 ]]; then
    fail "Unknown stop option: $1"
  fi

  local pid
  if ! pid="$(pid_value)"; then
    rm -f "$MURPH_PID_FILE"
    printf 'Murph is not running in background mode.\n'
    return
  fi

  if ! is_pid_running "$pid"; then
    rm -f "$MURPH_PID_FILE"
    printf 'Removed stale PID file.\n'
    return
  fi

  kill "$pid" >/dev/null 2>&1 || true
  local attempt
  for attempt in {1..20}; do
    if ! is_pid_running "$pid"; then
      rm -f "$MURPH_PID_FILE"
      printf 'Murph stopped.\n'
      return
    fi
    sleep 0.25
  done

  if [[ "$force" == true ]]; then
    kill -9 "$pid" >/dev/null 2>&1 || true
    rm -f "$MURPH_PID_FILE"
    printf 'Murph force-stopped.\n'
    return
  fi

  fail "Murph did not stop within 5 seconds. Run: murph stop --force"
}

status() {
  local pid=""
  if pid="$(pid_value)" && is_pid_running "$pid"; then
    if health_check_murph; then
      printf 'Murph is running.\n'
      printf 'URL: %s\n' "$MURPH_URL"
      printf 'PID: %s\n' "$pid"
      return
    fi
    if health_check; then
      printf 'Murph PID exists, but %s is responding with a non-Murph health payload.\n' "$MURPH_URL"
      printf 'PID: %s\n' "$pid"
      return 1
    fi
    printf 'Murph PID exists, but the health check is failing.\n'
    printf 'PID: %s\n' "$pid"
    printf 'Run: murph logs\n'
    return 1
  fi

  if health_check_murph; then
    printf 'Murph is responding at %s, but no CLI PID file exists.\n' "$MURPH_URL"
    return
  fi
  if health_check; then
    printf 'A non-Murph server is responding at %s.\n' "$MURPH_URL"
    return 1
  fi

  rm -f "$MURPH_PID_FILE"
  printf 'Murph is not running.\n'
  printf 'Start with: murph start\n'
}

doctor() {
  require_app
  cd "$MURPH_APP_DIR"
  ./install.sh --doctor
}

setup_command() {
  require_app
  have_command node || fail "node is required for murph setup."
  cd "$MURPH_APP_DIR"
  MURPH_DISTRIBUTION="$(default_distribution)" node shared/cli/setup-cli.mjs "$@"
}

credentials_command() {
  require_app
  have_command node || fail "node is required for murph credentials."
  cd "$MURPH_APP_DIR"
  node shared/cli/credentials-cli.mjs "$@"
}

admin_command() {
  [[ "$(default_distribution)" != "personal" ]] || fail "Murph Personal does not include Team subscriber admin commands."
  require_app
  have_command node || fail "node is required for murph admin."
  cd "$MURPH_APP_DIR"
  node shared/cli/admin-cli.mjs "$@"
}

agent_command() {
  require_app
  have_command node || fail "node is required for murph agent."

  local ensure_server=true
  local args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        ensure_server=false
        args+=("$1")
        ;;
      --no-server)
        fail "murph agent --no-server is no longer supported. Run murph agent so Murph can start the local server for setup, integration, plugin, and policy tools."
        ;;
      *)
        args+=("$1")
        ;;
    esac
    shift
  done

  if [[ "$ensure_server" == true ]]; then
    if health_check; then
      printf 'Murph server is running at %s\n' "$MURPH_URL"
    else
      printf 'Starting Murph server for agent tools.\n'
      start_background "$(default_distribution)"
    fi
  fi

  cd "$MURPH_APP_DIR"
  if [[ "${#args[@]}" -eq 0 ]]; then
    node shared/cli/agent-cli.mjs
  else
    node shared/cli/agent-cli.mjs "${args[@]}"
  fi
}

show_logs() {
  local follow=false
  if [[ "${1:-}" == "-f" || "${1:-}" == "--follow" ]]; then
    follow=true
  elif [[ $# -gt 0 ]]; then
    fail "Unknown logs option: $1"
  fi

  local log_file="$MURPH_LOG_FILE"
  if [[ ! -f "$log_file" && -f "$MURPH_APP_DIR/.murph-install.log" ]]; then
    log_file="$MURPH_APP_DIR/.murph-install.log"
  fi
  [[ -f "$log_file" ]] || fail "No Murph logs found yet."

  if [[ "$follow" == true ]]; then
    tail -f "$log_file"
  else
    tail -n 100 "$log_file"
  fi
}

policy_usage() {
  cat <<'EOF'
Usage: murph policy <command> [options]

Commands:
  profiles                                      List available policy profiles.
  preview [--profile NAME] [--mode MODE] [--session-mode MODE] [--override-file FILE] [--rules-file FILE]
  get                                           Show local policy config.
  set [--profile NAME] [--mode MODE]            Set the local policy profile or execution mode.
EOF
}

policy_profiles() {
  [[ $# -eq 0 ]] || fail "profiles does not accept options."
  require_http_api
  curl -fsS "$MURPH_URL/api/gateway/policy-profiles" | pretty_json
}

policy_preview() {
  local profile="" mode="" session_mode="" override_file="" rules_file=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --profile)
        profile="${2:-}"
        [[ -n "$profile" ]] || fail "--profile requires a value."
        shift 2
        ;;
      --mode)
        mode="${2:-}"
        [[ -n "$mode" ]] || fail "--mode requires a value."
        shift 2
        ;;
      --session-mode)
        session_mode="${2:-}"
        [[ -n "$session_mode" ]] || fail "--session-mode requires a value."
        shift 2
        ;;
      --override-file)
        override_file="${2:-}"
        [[ -f "$override_file" ]] || fail "--override-file requires a readable file."
        shift 2
        ;;
      --rules-file)
        rules_file="${2:-}"
        [[ -f "$rules_file" ]] || fail "--rules-file requires a readable file."
        shift 2
        ;;
      *)
        fail "Unknown preview option: $1"
        ;;
    esac
  done

  require_http_api
  local body
  body="$(PROFILE="$profile" MODE="$mode" SESSION_MODE="$session_mode" OVERRIDE_FILE="$override_file" RULES_FILE="$rules_file" node <<'NODE'
const fs = require('fs');
const body = {};
if (process.env.PROFILE) body.profileName = process.env.PROFILE;
if (process.env.MODE) body.mode = process.env.MODE;
if (process.env.SESSION_MODE) body.sessionMode = process.env.SESSION_MODE;
if (process.env.OVERRIDE_FILE) body.overrideRaw = fs.readFileSync(process.env.OVERRIDE_FILE, 'utf8');
if (process.env.RULES_FILE) body.scopedRules = JSON.parse(fs.readFileSync(process.env.RULES_FILE, 'utf8'));
process.stdout.write(JSON.stringify(body));
NODE
)"
  curl -fsS -H 'content-type: application/json' -d "$body" "$MURPH_URL/api/gateway/policy/preview" | pretty_json
}

policy_get() {
  [[ $# -eq 0 ]] || fail "get does not accept options."
  require_http_api
  curl -fsS "$MURPH_URL/api/gateway/policy/config" | pretty_json
}

policy_set() {
  local profile="" mode=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --profile)
        profile="${2:-}"
        [[ -n "$profile" ]] || fail "--profile requires a value."
        shift 2
        ;;
      --mode)
        mode="${2:-}"
        [[ -n "$mode" ]] || fail "--mode requires a value."
        shift 2
        ;;
      *)
        fail "Unknown set option: $1"
        ;;
    esac
  done
  [[ -n "$profile" || -n "$mode" ]] || fail "set requires --profile NAME or --mode MODE."

  require_http_api
  local body
  body="$(PROFILE="$profile" MODE="$mode" node - <<'NODE'
const body = {};
if (process.env.PROFILE) body.profileName = process.env.PROFILE;
if (process.env.MODE) body.mode = process.env.MODE;
process.stdout.write(JSON.stringify(body));
NODE
)"
  curl -fsS -X PUT -H 'content-type: application/json' -d "$body" "$MURPH_URL/api/gateway/policy/config" | pretty_json
}

policy_command() {
  local subcommand="${1:-help}"
  shift || true
  case "$subcommand" in
    profiles)
      policy_profiles "$@"
      ;;
    preview)
      policy_preview "$@"
      ;;
    get)
      policy_get "$@"
      ;;
    set)
      policy_set "$@"
      ;;
    help|-h|--help)
      policy_usage
      ;;
    *)
      policy_usage >&2
      exit 1
      ;;
  esac
}

open_app() {
  local url="$MURPH_URL/setup"
  if have_command open; then
    open "$url"
  elif have_command xdg-open; then
    xdg-open "$url"
  else
    printf '%s\n' "$url"
  fi
}

build_app() {
  require_app
  cd "$MURPH_APP_DIR"
  npm run build
}

prune_install_payload() {
  require_app
  cd "$MURPH_APP_DIR"
  if [[ -f scripts/prune-install.sh ]]; then
    bash scripts/prune-install.sh "$MURPH_APP_DIR"
  else
    printf 'scripts/prune-install.sh is missing. Skipping install pruning.\n'
  fi
}

update_app() {
  require_app
  local was_running=false
  local pid
  if pid="$(pid_value)" && is_pid_running "$pid"; then
    was_running=true
    stop_background
  fi

  local tmp_dir archive_file source_dir candidate preserve_dir
  tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/murph-update.XXXXXX")"
  archive_file="$tmp_dir/murph.tar.gz"
  preserve_dir="$tmp_dir/preserve"
  cleanup_update() {
    rm -rf "$tmp_dir"
  }
  trap cleanup_update EXIT

  have_command curl || fail "curl is required for murph update."
  have_command tar || fail "tar is required for murph update."

  printf 'Downloading latest Murph source.\n'
  curl -fsSL "$SOURCE_ARCHIVE_URL" -o "$archive_file"
  tar -xzf "$archive_file" -C "$tmp_dir"

  source_dir=""
  for candidate in "$tmp_dir"/*; do
    if [[ -d "$candidate" ]]; then
      source_dir="$candidate"
      break
    fi
  done
  [[ -n "$source_dir" && -f "$source_dir/package.json" ]] || fail "Downloaded archive did not contain a Murph source tree."

  mkdir -p "$preserve_dir"
  if [[ -d "$MURPH_APP_DIR/data" ]]; then
    cp -R "$MURPH_APP_DIR/data" "$preserve_dir/data"
  fi

  cp -R "$source_dir"/. "$MURPH_APP_DIR"/
  if [[ -d "$preserve_dir/data" ]]; then
    rm -rf "$MURPH_APP_DIR/data"
    cp -R "$preserve_dir/data" "$MURPH_APP_DIR/data"
  fi

  cd "$MURPH_APP_DIR"
  npm install
  npm run build
  prune_install_payload

  if [[ "$was_running" == true ]]; then
    start_background
  else
    printf 'Murph updated. Start with: murph start\n'
  fi
}

canonical_path() {
  local target="$1"
  local dir base
  dir="$(dirname "$target")"
  base="$(basename "$target")"
  if [[ -d "$dir" ]]; then
    (cd "$dir" >/dev/null 2>&1 && printf '%s/%s\n' "$(pwd -P)" "$base")
  else
    printf '%s\n' "$target"
  fi
}

path_is_within() {
  local child parent
  child="$(canonical_path "$1")"
  parent="$(canonical_path "$2")"
  [[ "$child" == "$parent" || "$child" == "$parent"/* ]]
}

dangerous_path() {
  local target
  target="$(canonical_path "$1")"
  [[ -z "$target" || "$target" == "/" || "$target" == "." || "$target" == "$HOME" ]]
}

is_murph_app_dir() {
  local dir="$1"
  [[ -f "$dir/package.json" && ( -f "$dir/murph-team/cli/murph" || -f "$dir/murph-personal/cli/murph" ) ]] &&
    grep -q '"name"[[:space:]]*:[[:space:]]*"murph"' "$dir/package.json"
}

print_uninstall_usage() {
  cat <<'EOF'
Usage: murph uninstall [--dry-run] [--yes] [--force]

Options:
  --dry-run  Show what would be removed without deleting files.
  --yes      Skip confirmation.
  --force    Force-stop PID-managed Murph before removing files.
EOF
}

remove_uninstall_path() {
  local dry_run="$1"
  local label="$2"
  local target="$3"

  [[ -n "$target" ]] || return
  if [[ ! -e "$target" && ! -L "$target" ]]; then
    return
  fi
  if dangerous_path "$target"; then
    fail "Refusing to remove unsafe $label path: $target"
  fi

  printf 'Remove %-16s %s\n' "$label:" "$target"
  if [[ "$dry_run" == false ]]; then
    rm -rf "$target"
  fi
}

remove_cli_link() {
  local dry_run="$1"
  local cli_name cli_path

  for cli_name in murph murph-team murph-personal; do
    cli_path="$MURPH_BIN_DIR/$cli_name"
    [[ -e "$cli_path" || -L "$cli_path" ]] || continue

    if [[ -L "$cli_path" ]]; then
      local target
      target="$(readlink "$cli_path")"
      if [[ "$target" != /* ]]; then
        target="$(canonical_path "$(dirname "$cli_path")/$target")"
      fi
      if path_is_within "$target" "$MURPH_HOME" || path_is_within "$target" "$MURPH_APP_DIR"; then
        remove_uninstall_path "$dry_run" "CLI link" "$cli_path"
        continue
      fi
      printf 'Skip CLI link: %s points outside this Murph install.\n' "$cli_path"
      continue
    fi

    if grep -q 'Murph' "$cli_path" 2>/dev/null && grep -q 'MURPH_HOME' "$cli_path" 2>/dev/null; then
      remove_uninstall_path "$dry_run" "CLI file" "$cli_path"
    else
      printf 'Skip CLI path: %s is not a Murph-managed link.\n' "$cli_path"
    fi
  done
}

confirm_uninstall() {
  local yes="$1"
  [[ "$yes" == true ]] && return
  if [[ ! -t 0 ]]; then
    fail "Refusing to uninstall without confirmation. Re-run with: murph uninstall --yes"
  fi
  printf '\nThis will remove Murph-owned local files and credentials.\n'
  printf 'Type "uninstall" to continue: '
  local answer
  read -r answer
  [[ "$answer" == "uninstall" ]] || fail "Uninstall cancelled."
}

assert_safe_murph_home() {
  [[ -d "$MURPH_HOME" || -f "$MURPH_HOME" || -L "$MURPH_HOME" ]] || return
  local home_base
  home_base="$(basename "$MURPH_HOME")"
  if [[ "$home_base" != ".murph" && "$home_base" != *murph* ]]; then
    fail "Refusing to remove MURPH_HOME because it is not clearly Murph-owned: $MURPH_HOME"
  fi
}

stop_for_uninstall() {
  local dry_run="$1"
  local force="$2"
  local pid

  if pid="$(pid_value)" && is_pid_running "$pid"; then
    if [[ "$dry_run" == true ]]; then
      printf 'Would stop Murph PID: %s\n' "$pid"
    elif [[ "$force" == true ]]; then
      stop_background --force
    else
      stop_background
    fi
  elif [[ -f "$MURPH_PID_FILE" && "$dry_run" == false ]]; then
    rm -f "$MURPH_PID_FILE"
  fi

  if health_check; then
    if [[ "$force" == true ]]; then
      printf 'Warning: Murph still responds at %s; continuing because --force was provided.\n' "$MURPH_URL"
    else
      fail "Murph is still responding at $MURPH_URL. Stop that process or re-run with --force."
    fi
  fi
}

uninstall_command() {
  local dry_run=false
  local yes=false
  local force=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)
        dry_run=true
        ;;
      --yes)
        yes=true
        ;;
      --force)
        force=true
        ;;
      -h|--help)
        print_uninstall_usage
        return
        ;;
      *)
        fail "Unknown uninstall option: $1"
        ;;
    esac
    shift
  done

  printf 'Murph uninstall plan\n'
  printf 'App dir:  %s\n' "$MURPH_APP_DIR"
  printf 'Home dir: %s\n' "$MURPH_HOME"
  printf 'CLI path: %s/murph\n' "$MURPH_BIN_DIR"
  printf '\n'

  assert_safe_murph_home
  if [[ "$dry_run" == false ]]; then
    confirm_uninstall "$yes"
  fi

  stop_for_uninstall "$dry_run" "$force"
  remove_cli_link "$dry_run"

  local remove_app_dir=false
  if path_is_within "$MURPH_APP_DIR" "$MURPH_HOME"; then
    remove_app_dir=false
  elif [[ -n "$MURPH_APP_DIR_EXPLICIT" || -n "$MURPH_INSTALL_DIR_EXPLICIT" ]] && is_murph_app_dir "$MURPH_APP_DIR"; then
    remove_app_dir=true
  fi

  if [[ "$remove_app_dir" == true ]]; then
    remove_uninstall_path "$dry_run" "app dir" "$MURPH_APP_DIR"
  elif [[ -d "$MURPH_APP_DIR" ]]; then
    remove_uninstall_path "$dry_run" "app data" "$MURPH_APP_DIR/data"
    remove_uninstall_path "$dry_run" "install log" "$MURPH_APP_DIR/.murph-install.log"
  fi

  if [[ -d "$MURPH_HOME" || -f "$MURPH_HOME" || -L "$MURPH_HOME" ]]; then
    remove_uninstall_path "$dry_run" "home dir" "$MURPH_HOME"
  fi

  if [[ "$dry_run" == true ]]; then
    printf '\nDry run complete. Nothing was removed.\n'
  else
    printf '\nMurph uninstall complete.\n'
    printf 'Reinstall with: curl -fsSL https://murph-agent.com/install.sh | bash\n'
  fi
}

command="${1:-help}"
shift || true

case "$command" in
  start)
    background=false
    distribution="$(default_distribution)"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --background)
          background=true
          ;;
        *)
          fail "Unknown start option: $1"
          ;;
      esac
      shift
    done
    if [[ "$background" == true ]]; then
      start_background "$distribution"
    else
      start_foreground "$distribution"
    fi
    ;;
  stop)
    stop_background "$@"
    ;;
  restart)
    [[ $# -eq 0 ]] || fail "restart does not accept options."
    stop_background
    if health_check; then
      stop_responding_murph || fail "Murph is responding at $MURPH_URL, but this CLI could not stop it. Stop that process and run: murph start --background"
    fi
    start_background "$(default_distribution)"
    ;;
  status)
    [[ $# -eq 0 ]] || fail "status does not accept options."
    status
    ;;
  doctor)
    [[ $# -eq 0 ]] || fail "doctor does not accept options."
    doctor
    ;;
  setup)
    setup_command "$@"
    ;;
  credentials)
    credentials_command "$@"
    ;;
  admin)
    admin_command "$@"
    ;;
  agent)
    agent_command "$@"
    ;;
  policy)
    policy_command "$@"
    ;;
  logs)
    show_logs "$@"
    ;;
  open)
    [[ $# -eq 0 ]] || fail "open does not accept options."
    open_app
    ;;
  build)
    [[ $# -eq 0 ]] || fail "build does not accept options."
    build_app
    ;;
  update)
    [[ $# -eq 0 ]] || fail "update does not accept options."
    update_app
    ;;
  uninstall)
    uninstall_command "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
