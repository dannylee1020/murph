{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"],
    "declaration": true,
    "declarationMap": true,
    "noEmit": false
  },
  "include": [
    "app/*.d.ts",
    "app/*.ts",
    "app/server/**/*.ts",
    "app/runtime/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
