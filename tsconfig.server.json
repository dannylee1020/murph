{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"],
    "declaration": true,
    "declarationMap": true,
    "noEmit": false
  },
  "include": [
    "shared/*.d.ts",
    "shared/*.ts",
    "shared/server/**/*.ts",
    "murph/runtime/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
